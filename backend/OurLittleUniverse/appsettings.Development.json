{
  "App": {
    "Name": "Arova.Api",
    "DisplayName": "Arova API (Development)",
    "Version": "1.0.0-dev"
  },
  "ProductProfile": {
    "Mode": "Portfolio"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=ArovaDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "Issuer": "OurLittleUniverse.Api.Development",
    "Audience": "OurLittleUniverse.Client.Development",
    "SecretKey": "development-only-secret-key-change-before-production-2026",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  }
}

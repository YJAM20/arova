{
  "App": {
    "Name": "Arova.Api",
    "DisplayName": "Arova API (Development)",
    "Version": "1.0.0-dev"
  },
  "ProductProfile": {
    "Mode": "Portfolio"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Database": {
    "Provider": "SqlServer",
    "AutoMigrate": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=ArovaDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true",
    "SqliteConnection": "Data Source=loveuniverse-dev.db"
  },
  "JwtSettings": {
    "Issuer": "OurLittleUniverse.Api.Development",
    "Audience": "OurLittleUniverse.Client.Development",
    "SecretKey": "development-only-secret-key-change-before-production-2026",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "Sms": {
    "Provider": "Console",
    "TwilioAccountSid": "",
    "TwilioAuthToken": "",
    "TwilioFromNumber": ""
  },
  "Authentication": {
    "GoogleClientId": ""
  },
  "Stripe": {
    "ApiKey": "",
    "WebhookSecret": "",
    "ProPriceId": "price_pro_placeholder",
    "PlatinumPriceId": "price_plat_placeholder"
  }
}

{
  "App": {
    "Name": "Arova.Api",
    "DisplayName": "Arova API",
    "Version": "1.0.0"
  },
  "ProductProfile": {
    "Mode": "Portfolio"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "Email": {
    "Provider": "Console",
    "FromEmail": "no-reply@your-domain.com",
    "FromName": "Arova",
    "ResendApiKey": "",
    "DailyDigestEnabled": false
  },
  "Sms": {
    "Provider": "Console",
    "TwilioAccountSid": "",
    "TwilioAuthToken": "",
    "TwilioFromNumber": ""
  },
  "Authentication": {
    "GoogleClientId": ""
  },
  "Stripe": {
    "ApiKey": "",
    "WebhookSecret": "",
    "ProPriceId": "price_pro_placeholder",
    "PlatinumPriceId": "price_plat_placeholder"
  },
  "AllowedHosts": "*"
}

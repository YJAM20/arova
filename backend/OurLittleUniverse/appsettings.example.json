{
  "App": {
    "Name": "Arova.Api",
    "DisplayName": "Arova API (Example)",
    "Version": "1.0.0"
  },
  "ProductProfile": {
    "Mode": "Portfolio" // "Portfolio" or "Product"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=loveuniverse-dev.db"
  },
  "JwtSettings": {
    "Issuer": "OurLittleUniverse.Api.Development",
    "Audience": "OurLittleUniverse.Client.Development",
    "SecretKey": "CHANGE_ME_DEVELOPMENT_ONLY_JWT_SECRET_KEY_MINIMUM_32_CHARS",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "AllowedHosts": "*"
}
